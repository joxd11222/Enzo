{
  "name": "enzocli",
  "version": "1.0.0",
  "description": "A CLI for AI coding with fully free AI agents using NVIDIA Build API",
  "main": "dist/index.js",
  "bin": {
    "enzo": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess \"node dist/index.js\""
  },
  "keywords": [
    "ai",
    "cli",
    "nvidia",
    "coding"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "openai": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3"
  }
}